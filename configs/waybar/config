{
  "layer": "bot",
  /*"start_hidden": "true",
  "ipc": "true",
  "mode": "hide",*/
  "reload-style-on-change":true,
  "spacing": 5,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 0,
  "position": "top",
  "margin-right": 10,
  "margin-left": 10,
  "modules-left": [
    "custom/power",
    "sway/workspaces",
    "tray",
    "sway/mode"
  ],
  "modules-center":[
    "custom/applauncher"
  ], 
  "modules-right": [
    "network",
    "backlight",
    "bluetooth",
    "pulseaudio",
    "clock",
    "battery",
    "custom/notification"

  ],
  "bluetooth":{
    "format-on": "≤░Γψ",
    "format-connected": "≤░Γ▒",
    "tooltip": true,
    "tooltip-format-on": "≤░Γψ No Connections",
    "tooltip-format-connected-battery": "≤░Γ▒ {device_alias} {device_battery_percentage}%",
    "on-click": "kitty -1 bluetui && exit"
  },
  "tray": {
    "spacing": 5,
  },
  "custom/power":{
    "format": "ΎΑΣ",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi-power-menu",
    "tooltip": false
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "backlight": {
    "device": "intel_backlight",
    "tooltip-format": "{icon} {percent}%",
    "format": "{icon}",
    "format-icons": ["ΎΕΣ", "≤░Δδ", "≤░Δε", "≤░Δζ", "≤░Δη", "≤░Δθ", "≤░Δι"]
  },
   "custom/applauncher": {
    "format": "ΎΤς",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi",
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "clock": {
    "format": "≤░ΖΡ {:%r}",
    "tooltip": true,
    "tooltip-format": "Ός░ {:%d/%m/%Y}",
    "interval": 1
  },
  "network": {
    "tooltip-format-wifi": "ΎΘτ  {essid}",
    "tooltip-format-ethernet": "≤░ΙΑ  {ifname}",
    "tooltip-format-disconnected": "≤░νχ  No Network",
    "format-wifi": "ΎΘτ ",
    "format-ethernet": "≤░ΙΑ ",
    "format-disconnected": "≤░νχ ",
    "interval": 5,
    "tooltip": true,
    "on-click": "kitty -1 nmtui && exit"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 150,
    "tooltip-format": "{icon} {volume}%",
    "format": "{icon}",
    "format-icons": [
      "ΎΑο",
      "ΎΑπ",
      "ΎΑρ "
    ],
    "nospacing": 1,
    "format-muted": "Ό╗ρ ",
    "on-click": "kitty -1 pipemixer && exit",
    "tooltip": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "≤░ΓΕ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "≤▒ΙΣ {capacity}%",
    "format-icons": [
      "≤▒Λκ",
      "≤▒Λλ",
      "≤▒Λμ"
    ]
  }
}
